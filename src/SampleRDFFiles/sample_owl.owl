<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:ex="http://example.org/starlion-owl#">

  <owl:Ontology rdf:about="http://example.org/starlion-owl"/>

  <owl:Class rdf:about="http://example.org/starlion-owl#GraphEntity"/>
  <owl:Class rdf:about="http://example.org/starlion-owl#NodeEntity">
    <rdfs:subClassOf rdf:resource="http://example.org/starlion-owl#GraphEntity"/>
  </owl:Class>

  <owl:ObjectProperty rdf:about="http://example.org/starlion-owl#connectsTo">
    <rdfs:domain rdf:resource="http://example.org/starlion-owl#NodeEntity"/>
    <rdfs:range rdf:resource="http://example.org/starlion-owl#NodeEntity"/>
  </owl:ObjectProperty>

  <owl:NamedIndividual rdf:about="http://example.org/starlion-owl#NodeA">
    <rdf:type rdf:resource="http://example.org/starlion-owl#NodeEntity"/>
    <ex:connectsTo rdf:resource="http://example.org/starlion-owl#NodeB"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://example.org/starlion-owl#NodeB">
    <rdf:type rdf:resource="http://example.org/starlion-owl#NodeEntity"/>
  </owl:NamedIndividual>

</rdf:RDF>
